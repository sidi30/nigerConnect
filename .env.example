# ───────────────────────────────────────────────
# API
# ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ───────────────────────────────────────────────
# Database
# ───────────────────────────────────────────────
DATABASE_URL=postgresql://nigerconnect:nigerconnect@localhost:5433/nigerconnect?schema=public

# ───────────────────────────────────────────────
# Redis
# ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────
# Storage (MinIO in dev, S3 in prod)
# Two buckets are used:
#   - S3_BUCKET         : public media (avatars, post photos, stories, public covers)
#                         Served via CDN, downloadable without auth.
#   - S3_PRIVATE_BUCKET : sensitive uploads (identity documents, private conversation
#                         media). NEVER publicly listable. Access via presigned GET only.
# ───────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nigerconnect
S3_PRIVATE_BUCKET=nigerconnect-private
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
CDN_URL=http://localhost:9000/nigerconnect

# ───────────────────────────────────────────────
# JWT (RS256 keypair + rotation + claims)
# ───────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
# Optional: accept tokens signed with a previous key during a rotation window.
# Set this to the PEM of the OLD public key for ~access-token TTL + a safety margin,
# then remove once all active tokens have expired.
JWT_PREVIOUS_PUBLIC_KEY_PATH=
JWT_ACCESS_EXPIRES=15m
# Shortened from 30d → 14d (shorter exposure window if a refresh leaks).
JWT_REFRESH_EXPIRES=14d
JWT_ISSUER=nigerconnect-api
JWT_AUDIENCE=nigerconnect-app

# ───────────────────────────────────────────────
# Column-level encryption (AES-256-GCM)
# Encrypts MFA secrets and future PII at rest.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED in production. Rotate by re-encrypting all affected rows.
# ───────────────────────────────────────────────
DATA_ENCRYPTION_KEY=

# ───────────────────────────────────────────────
# CORS
# ───────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:3001,exp://localhost:19000

# ───────────────────────────────────────────────
# OAuth
# ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Mobile sign-in — create separate OAuth clients in Google Cloud Console:
#   - Application type: Web application  → GOOGLE_CLIENT_ID_WEB
#   - Application type: Android          → GOOGLE_CLIENT_ID_ANDROID (package com.nigerconnect.app + SHA-1)
#   - Application type: iOS              → GOOGLE_CLIENT_ID_IOS     (bundle id com.nigerconnect.app)
# The API verifies the ID token audience against every client ID listed here.
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_IOS=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ───────────────────────────────────────────────
# Mail (SMTP)
# ───────────────────────────────────────────────
# Prod: Resend recommandé. Dev: laisser vide → emails loggués dans la console.
MAIL_FROM="NigerConnect <no-reply@nigerconnect.local>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# URL publique du front pour les liens envoyés par email
APP_WEB_URL=http://localhost:3000

# ───────────────────────────────────────────────
# Push notifications (FCM)
# ───────────────────────────────────────────────
# Base64 du JSON du service account Firebase
FCM_SERVICE_ACCOUNT_JSON=

# ───────────────────────────────────────────────
# Monitoring
# ───────────────────────────────────────────────
SENTRY_DSN=
# Fraction des transactions tracées (0.0–1.0). Défaut: 1.0 en dev, 0.3 en prod.
SENTRY_TRACES_SAMPLE_RATE=
AXIOM_TOKEN=

# ───────────────────────────────────────────────
# Mobile (Expo)
# ───────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
