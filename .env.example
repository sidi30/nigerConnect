# ───────────────────────────────────────────────
# API
# ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ───────────────────────────────────────────────
# Database
# ───────────────────────────────────────────────
DATABASE_URL=postgresql://nigerconnect:nigerconnect@localhost:5432/nigerconnect?schema=public

# ───────────────────────────────────────────────
# Redis
# ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────
# Storage (MinIO in dev, S3 in prod)
# ───────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nigerconnect
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
CDN_URL=http://localhost:9000/nigerconnect

# ───────────────────────────────────────────────
# JWT (RS256 keypair)
# ───────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ───────────────────────────────────────────────
# CORS
# ───────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:3001,exp://localhost:19000

# ───────────────────────────────────────────────
# OAuth
# ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ───────────────────────────────────────────────
# Notifications
# ───────────────────────────────────────────────
FCM_SERVICE_ACCOUNT_JSON=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ───────────────────────────────────────────────
# Monitoring
# ───────────────────────────────────────────────
SENTRY_DSN=
AXIOM_TOKEN=

# ───────────────────────────────────────────────
# Mobile (Expo)
# ───────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
