// NigerConnect — Schéma Prisma
// Phases 1-2 : User complet, identity_documents, refresh_tokens, push_tokens.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  moderator
  admin
}

enum UserStatus {
  active
  suspended
  banned
}

enum IdentityStatus {
  not_submitted
  pending
  approved
  rejected
}

enum PrivacyLevel {
  public
  friends
  private
}

enum OAuthProvider {
  google
  facebook
  apple
}

enum DocumentStatus {
  pending
  approved
  rejected
}

enum Platform {
  ios
  android
  web
}

model User {
  id              String         @id @default(uuid()) @db.Uuid
  email           String?        @unique @db.VarChar(255)
  phone           String?        @unique @db.VarChar(20)
  passwordHash    String?        @map("password_hash") @db.VarChar(255)
  oauthProvider   OAuthProvider? @map("oauth_provider")
  oauthProviderId String?        @map("oauth_provider_id") @db.VarChar(255)

  firstName   String? @map("first_name") @db.VarChar(100)
  lastName    String? @map("last_name") @db.VarChar(100)
  displayName String? @map("display_name") @db.VarChar(100)
  bio         String? @db.Text
  avatarUrl   String? @map("avatar_url") @db.VarChar(500)
  coverUrl    String? @map("cover_url") @db.VarChar(500)

  city            String?  @db.VarChar(100)
  countryCode     String?  @map("country_code") @db.Char(2)
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  // Map visibility is OFF by default (safety-by-default, RGPD art.25): a member
  // only appears on the public map after an explicit opt-in. Mirrors
  // proximityAlerts, which is likewise opt-in.
  showOnMap       Boolean  @default(false) @map("show_on_map")
  proximityAlerts Boolean  @default(false) @map("proximity_alerts")
  proximityRadius Int      @default(100) @map("proximity_radius")

  // Ephemeral, PRIVATE proximity-matching position. Written by the foreground
  // proximity ping and used ONLY by the Haversine matcher (filtered by
  // proximityUpdatedAt freshness). NEVER selected by the public map surfaces
  // (markers / nearby / clusters) so live GPS never leaks through the
  // city-coarse latitude/longitude pin.
  proximityLat       Decimal?  @db.Decimal(10, 7) @map("proximity_lat")
  proximityLon       Decimal?  @db.Decimal(10, 7) @map("proximity_lon")
  proximityUpdatedAt DateTime? @map("proximity_updated_at") @db.Timestamptz

  languages    String[]     @default(["fr"])
  privacyLevel PrivacyLevel @default(friends) @map("privacy_level")

  emailVerified  Boolean        @default(false) @map("email_verified")
  phoneVerified  Boolean        @default(false) @map("phone_verified")
  identityStatus IdentityStatus @default(not_submitted) @map("identity_status")
  // Ambassador badge: a curated, admin-managed distinction (community leaders /
  // official ambassadors) shown ALONGSIDE the identity-verified badge — they are
  // independent (a user can be identity-verified, an ambassador, both, or neither).
  // Toggled only from the tenant admin console; never self-assigned.
  isAmbassador   Boolean        @default(false) @map("is_ambassador")
  role           UserRole       @default(user)
  status         UserStatus     @default(active)

  // Aggregate of reviews received on this profile (Feature: avis).
  // Maintained transactionally by ReviewService — never written elsewhere.
  ratingAvg   Float @default(0) @map("rating_avg")
  ratingCount Int   @default(0) @map("rating_count")

  mfaEnabled       Boolean   @default(false) @map("mfa_enabled")
  mfaSecret        String?   @map("mfa_secret") @db.VarChar(255)
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamptz
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz
  lastLoginIp      String?   @map("last_login_ip") @db.Inet

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  identityDocuments       IdentityDocument[]   @relation("UserIdentityDocuments")
  reviewedDocuments       IdentityDocument[]   @relation("DocumentReviewer")
  refreshTokens           RefreshToken[]
  pushTokens              PushToken[]
  mfaRecoveryCodes        MfaRecoveryCode[]
  emailTokens             EmailToken[]
  photos                  UserPhoto[]
  friendshipsSent         Friendship[]         @relation("FriendshipRequester")
  friendshipsReceived     Friendship[]         @relation("FriendshipAddressee")
  blocksMade              Block[]              @relation("BlockBlocker")
  blocksReceived          Block[]              @relation("BlockBlocked")
  posts                   Post[]
  likes                   Like[]
  comments                Comment[]
  conversationMemberships ConversationMember[]
  conversationsCreated    Conversation[]       @relation("ConversationCreator")
  messages                Message[]
  serviceRequests         ServiceRequest[]
  serviceResponses        ServiceResponse[]
  associationsCreated     Association[]        @relation("AssociationCreator")
  associationMemberships  AssociationMember[]
  notifications           Notification[]       @relation("NotificationRecipient")
  notificationsActedOn    Notification[]       @relation("NotificationActor")
  reportsMade             Report[]             @relation("ReportReporter")
  reportsReviewed         Report[]             @relation("ReportReviewer")
  pagesCreated            Page[]               @relation("PageCreator")
  pageFollows             PageFollower[]
  pageAdminOf             PageAdmin[]
  pollsCreated            Poll[]
  pollVotes               PollVote[]
  reviewsAuthored         Review[]             @relation("ReviewAuthor")
  reviewsReceived         Review[]             @relation("ReviewTargetUser")

  // ── Parrainage ──────────────────────────────────────────────────
  // Parrain direct (arbre). SetNull si le parrain supprime son compte —
  // on ne casse pas le filleul, on perd juste le lien de parenté.
  invitedById      String?      @map("invited_by_id") @db.Uuid
  invitedBy        User?        @relation("UserInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  invitees         User[]       @relation("UserInvitedBy")
  // Droit accordé par l'admin de créer des liens d'invitation RÉUTILISABLES
  // (1 lien → N inscriptions, partage en masse). L'invitation email/code
  // single-use reste ouverte à tous les inscrits vérifiés.
  canBulkInvite    Boolean      @default(false) @map("can_bulk_invite")
  // Par quelle invitation ce compte s'est inscrit (analytics réseau : permet de
  // compter les inscriptions par lien réutilisable). Distinct de invitedById
  // (l'arbre de parenté). SetNull si l'invitation est supprimée.
  invitedViaId     String?      @map("invited_via_id") @db.Uuid
  invitedVia       Invitation?  @relation("InvitationSignups", fields: [invitedViaId], references: [id], onDelete: SetNull)
  // DÉPRÉCIÉ (v2 réseau) : plus de quota dur ni d'expiration. Colonnes conservées
  // pour éviter une migration destructive ; plus lues ni posées par le code.
  inviteQuota      Int          @default(3) @map("invite_quota")
  // Compteur d'abus : +1 quand un filleul est banni. ≥ 3 → création d'invitation gelée.
  inviteAbuseFlags Int          @default(0) @map("invite_abuse_flags")

  invitesSent      Invitation[] @relation("UserInvitesSent")
  invitesAccepted  Invitation[] @relation("UserInviteAccepted")

  // Unique per OAuth identity so concurrent link-or-create requests can't mint
  // duplicate accounts (the DB is the final arbiter — see loginWithOAuth).
  // Both columns are nullable; Postgres treats NULLs as distinct, so the many
  // password-only users (provider + id both NULL) are unaffected.
  @@unique([oauthProvider, oauthProviderId])
  @@index([countryCode, city])
  @@index([latitude, longitude])
  @@index([showOnMap, status])
  @@index([invitedById])
  @@index([invitedViaId])
  @@map("users")
}

enum FriendshipStatus {
  pending
  accepted
  declined
}

enum PostVisibility {
  public
  friends
  association
}

enum MediaType {
  image
  video
}

enum ConversationType {
  direct
  group
}

enum MessageType {
  text
  image
  file
  system
}

enum ConversationRole {
  admin
  member
}

enum ServiceCategory {
  logement
  transport
  admin_category
  sante
  emploi
  business
  education
  autre
}

enum ServiceUrgency {
  urgent
  normal
}

enum ServiceStatus {
  open
  in_progress
  resolved
  closed
}

enum AssociationCategory {
  generaliste
  etudiants
  femmes
  jeunesse
  culture
  business
  sport
  religieux
}

enum AssociationRole {
  admin
  moderator
  member
}

enum MembershipStatus {
  pending
  approved
  rejected
}

enum PageKind {
  community
  cause
  business
  official
  group
}

enum PageRole {
  admin
  editor
}

enum ReviewTargetType {
  user
  page
}

enum NotificationType {
  friend_request
  friend_accepted
  like
  comment
  message
  service_response
  association_invite
  association_join_request
  association_join_approved
  association_join_rejected
  identity_approved
  identity_rejected
  proximity
  page_follow
  poll_new
  review_received
  system
  invite_accepted
  mention
}

// ── Parrainage ────────────────────────────────────────────────────

enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum InvitationKind {
  // Email/code à usage unique : une seule acceptation (pending → accepted).
  single_use
  // Lien partageable réutilisable : N inscriptions, jamais consommé
  // (status reste pending = actif). Réservé aux users canBulkInvite.
  reusable
}

enum ReportTargetType {
  user
  post
  message
  association
  comment
}

enum ReportReason {
  spam
  harassment
  inappropriate
  fake_identity
  scam
  other
}

enum ReportStatus {
  pending
  reviewed
  resolved
  dismissed
}

enum ReportAction {
  warning
  content_removed
  suspended
  banned
  none
}

model Friendship {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @map("requester_id") @db.Uuid
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String           @map("addressee_id") @db.Uuid
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendshipStatus @default(pending)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@map("friendships")
}

model Block {
  blockerId String   @map("blocker_id") @db.Uuid
  blocker   User     @relation("BlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String   @map("blocked_id") @db.Uuid
  blocked   User     @relation("BlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

enum EmailTokenType {
  reset_password
  verify_email
}

model EmailToken {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      EmailTokenType
  tokenHash String         @unique @map("token_hash") @db.VarChar(255)
  // sha256 of the 6-digit verification code (null for link-only tokens).
  codeHash  String?        @map("code_hash") @db.VarChar(255)
  // Wrong-code guess counter — caps brute-force on the low-entropy code.
  attempts  Int            @default(0)
  expiresAt DateTime       @map("expires_at") @db.Timestamptz
  usedAt    DateTime?      @map("used_at") @db.Timestamptz
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, type])
  @@map("email_tokens")
}

model Post {
  id             String         @id @default(uuid()) @db.Uuid
  authorId       String         @map("author_id") @db.Uuid
  author         User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content        String?        @db.Text
  visibility     PostVisibility @default(friends)
  associationId  String?        @map("association_id") @db.Uuid
  isStory        Boolean        @default(false) @map("is_story")
  storyExpiresAt DateTime?      @map("story_expires_at") @db.Timestamptz
  sharedPostId   String?        @map("shared_post_id") @db.Uuid
  sharedPost     Post?          @relation("PostShares", fields: [sharedPostId], references: [id])
  shares         Post[]         @relation("PostShares")
  likeCount      Int            @default(0) @map("like_count")
  commentCount   Int            @default(0) @map("comment_count")
  shareCount     Int            @default(0) @map("share_count")
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  media    PostMedia[]
  likes    Like[]
  comments Comment[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([associationId, createdAt(sort: Desc)])
  @@index([isStory, storyExpiresAt])
  @@map("posts")
}

model PostMedia {
  id           String    @id @default(uuid()) @db.Uuid
  postId       String    @map("post_id") @db.Uuid
  post         Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaUrl     String    @map("media_url") @db.VarChar(500)
  thumbnailUrl String?   @map("thumbnail_url") @db.VarChar(500)
  mediaType    MediaType @map("media_type")
  width        Int?
  height       Int?
  blurhash     String?   @db.VarChar(100)
  sortOrder    Int       @default(0) @map("sort_order")

  @@index([postId])
  @@map("post_media")
}

model Like {
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id") @db.Uuid
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([userId, postId])
  @@index([postId])
  @@map("likes")
}

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  postId    String    @map("post_id") @db.Uuid
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String    @map("author_id") @db.Uuid
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?   @map("parent_id") @db.Uuid
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  content   String    @db.Text
  likeCount Int       @default(0) @map("like_count")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([postId, createdAt])
  @@index([parentId])
  @@map("comments")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  user      User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String?          @db.Text
  data      Json?
  actorId   String?          @map("actor_id") @db.Uuid
  actor     User?            @relation("NotificationActor", fields: [actorId], references: [id])
  read      Boolean          @default(false)
  // History auto-expires (Feature: 24h notification history). Set by the service
  // at creation; the list endpoint filters out and purges rows past this instant.
  expiresAt DateTime?        @map("expires_at") @db.Timestamptz
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, read])
  @@index([expiresAt])
  @@map("notifications")
}

model Report {
  id           String           @id @default(uuid()) @db.Uuid
  reporterId   String?          @map("reporter_id") @db.Uuid
  reporter     User?            @relation("ReportReporter", fields: [reporterId], references: [id])
  targetType   ReportTargetType @map("target_type")
  targetId     String           @map("target_id") @db.Uuid
  reason       ReportReason
  description  String?          @db.Text
  status       ReportStatus     @default(pending)
  reviewedById String?          @map("reviewed_by") @db.Uuid
  reviewedBy   User?            @relation("ReportReviewer", fields: [reviewedById], references: [id])
  actionTaken  ReportAction?    @map("action_taken")
  note         String?          @db.Text
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt   DateTime?        @map("resolved_at") @db.Timestamptz

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@map("reports")
}

model UserPhoto {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String   @db.VarChar(500)
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  caption      String?  @db.Text
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, sortOrder])
  @@map("user_photos")
}

model Conversation {
  id                 String           @id @default(uuid()) @db.Uuid
  type               ConversationType @default(direct)
  name               String?          @db.VarChar(100)
  avatarUrl          String?          @map("avatar_url") @db.VarChar(500)
  createdById        String?          @map("created_by") @db.Uuid
  createdBy          User?            @relation("ConversationCreator", fields: [createdById], references: [id])
  lastMessageAt      DateTime?        @map("last_message_at") @db.Timestamptz
  lastMessagePreview String?          @map("last_message_preview") @db.Text
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz

  members  ConversationMember[]
  messages Message[]

  @@index([lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model ConversationMember {
  conversationId String           @map("conversation_id") @db.Uuid
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String           @map("user_id") @db.Uuid
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           ConversationRole @default(member)
  lastReadAt     DateTime?        @map("last_read_at") @db.Timestamptz
  unreadCount    Int              @default(0) @map("unread_count")
  muted          Boolean          @default(false)
  joinedAt       DateTime         @default(now()) @map("joined_at") @db.Timestamptz

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model ServiceRequest {
  id            String          @id @default(uuid()) @db.Uuid
  authorId      String          @map("author_id") @db.Uuid
  author        User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title         String          @db.VarChar(200)
  description   String?         @db.Text
  category      ServiceCategory
  urgency       ServiceUrgency  @default(normal)
  budget        String?         @db.VarChar(50)
  city          String?         @db.VarChar(100)
  countryCode   String?         @map("country_code") @db.Char(2)
  status        ServiceStatus   @default(open)
  responseCount Int             @default(0) @map("response_count")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  responses ServiceResponse[]
  ratings   ServiceRating[]

  @@index([status, createdAt(sort: Desc)])
  @@index([category, status])
  @@index([countryCode, status])
  @@map("service_requests")
}

model ServiceResponse {
  id          String         @id @default(uuid()) @db.Uuid
  requestId   String         @map("request_id") @db.Uuid
  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  responderId String         @map("responder_id") @db.Uuid
  responder   User           @relation(fields: [responderId], references: [id], onDelete: Cascade)
  message     String         @db.Text
  accepted    Boolean        @default(false)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  @@index([requestId])
  @@map("service_responses")
}

model ServiceRating {
  id          String         @id @default(uuid()) @db.Uuid
  requestId   String         @map("request_id") @db.Uuid
  request     ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  ratedUserId String         @map("rated_user_id") @db.Uuid
  rating      Int
  comment     String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  @@unique([requestId, ratedUserId])
  @@index([ratedUserId])
  @@map("service_ratings")
}

model Association {
  id               String              @id @default(uuid()) @db.Uuid
  name             String              @db.VarChar(200)
  description      String?             @db.Text
  logoUrl          String?             @map("logo_url") @db.VarChar(500)
  coverUrl         String?             @map("cover_url") @db.VarChar(500)
  category         AssociationCategory
  countryCode      String?             @map("country_code") @db.Char(2)
  city             String?             @db.VarChar(100)
  website          String?             @db.VarChar(300)
  contactEmail     String?             @map("contact_email") @db.VarChar(255)
  isVerified       Boolean             @default(false) @map("is_verified")
  requiresApproval Boolean             @default(false) @map("requires_approval")
  memberCount      Int                 @default(0) @map("member_count")
  createdById      String?             @map("created_by") @db.Uuid
  createdBy        User?               @relation("AssociationCreator", fields: [createdById], references: [id])
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  members AssociationMember[]
  events  AssociationEvent[]

  @@index([category, countryCode])
  @@map("associations")
}

model AssociationMember {
  associationId String           @map("association_id") @db.Uuid
  association   Association      @relation(fields: [associationId], references: [id], onDelete: Cascade)
  userId        String           @map("user_id") @db.Uuid
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          AssociationRole  @default(member)
  status        MembershipStatus @default(approved)
  joinedAt      DateTime         @default(now()) @map("joined_at") @db.Timestamptz

  @@id([associationId, userId])
  @@index([userId])
  @@map("association_members")
}

model AssociationEvent {
  id            String      @id @default(uuid()) @db.Uuid
  associationId String      @map("association_id") @db.Uuid
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  title         String      @db.VarChar(200)
  description   String?     @db.Text
  eventDate     DateTime    @map("event_date") @db.Timestamptz
  location      String?     @db.VarChar(200)
  coverUrl      String?     @map("cover_url") @db.VarChar(500)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  @@index([associationId, eventDate])
  @@map("association_events")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String       @map("sender_id") @db.Uuid
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String?      @db.Text
  messageType    MessageType  @default(text) @map("message_type")
  mediaUrl       String?      @map("media_url") @db.VarChar(500)
  replyToId      String?      @map("reply_to_id") @db.Uuid
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        Message[]    @relation("MessageReplies")
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz
  editedAt       DateTime?    @map("edited_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}

model IdentityDocument {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  user            User           @relation("UserIdentityDocuments", fields: [userId], references: [id], onDelete: Cascade)
  documentType    String         @map("document_type") @db.VarChar(30)
  fileUrl         String         @map("file_url") @db.VarChar(500)
  status          DocumentStatus @default(pending)
  reviewedById    String?        @map("reviewed_by") @db.Uuid
  reviewedBy      User?          @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?      @map("reviewed_at") @db.Timestamptz
  rejectionReason String?        @map("rejection_reason") @db.Text
  expiresAt       DateTime?      @map("expires_at") @db.Timestamptz
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([status])
  @@map("identity_documents")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  deviceName String?   @map("device_name") @db.VarChar(100)
  usedAt     DateTime? @map("used_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@map("refresh_tokens")
}

model PushToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @db.VarChar(500)
  platform  Platform
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([userId, token])
  @@map("push_tokens")
}

// Single-use TOTP recovery codes. Stored hashed (sha256); the plaintext is
// shown to the user exactly once at MFA enrollment. usedAt marks consumption.
model MfaRecoveryCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @map("code_hash") @db.VarChar(255)
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@map("mfa_recovery_codes")
}

// ── Pages (Feature: créer une page) ──────────────────────────────
// Generic user-created entity: communities, causes, businesses, official
// pages, groups. Distinct from Association (which keeps its own membership
// model). A Page has followers, admins, polls, and can receive reviews.
model Page {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(200)
  description   String?  @db.Text
  kind          PageKind @default(community)
  avatarUrl     String?  @map("avatar_url") @db.VarChar(500)
  coverUrl      String?  @map("cover_url") @db.VarChar(500)
  countryCode   String?  @map("country_code") @db.Char(2)
  city          String?  @db.VarChar(100)
  website       String?  @db.VarChar(300)
  contactEmail  String?  @map("contact_email") @db.VarChar(255)
  isVerified    Boolean  @default(false) @map("is_verified")
  followerCount Int      @default(0) @map("follower_count")
  ratingAvg     Float    @default(0) @map("rating_avg")
  ratingCount   Int      @default(0) @map("rating_count")
  createdById   String?  @map("created_by") @db.Uuid
  createdBy     User?    @relation("PageCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  followers PageFollower[]
  admins    PageAdmin[]
  polls     Poll[]
  reviews   Review[]       @relation("ReviewTargetPage")

  @@index([kind, countryCode])
  @@index([createdById])
  @@map("pages")
}

model PageFollower {
  pageId    String   @map("page_id") @db.Uuid
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([pageId, userId])
  @@index([userId])
  @@map("page_followers")
}

model PageAdmin {
  pageId    String   @map("page_id") @db.Uuid
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      PageRole @default(editor)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([pageId, userId])
  @@index([userId])
  @@map("page_admins")
}

// ── Polls / Sondages ─────────────────────────────────────────────
// A poll may belong to a page (pageId) or be standalone (pageId null).
model Poll {
  id          String    @id @default(uuid()) @db.Uuid
  pageId      String?   @map("page_id") @db.Uuid
  page        Page?     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  authorId    String    @map("author_id") @db.Uuid
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  question    String    @db.VarChar(300)
  multiChoice Boolean   @default(false) @map("multi_choice")
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  voteCount   Int       @default(0) @map("vote_count")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  options PollOption[]
  votes   PollVote[]

  @@index([pageId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("polls")
}

model PollOption {
  id        String @id @default(uuid()) @db.Uuid
  pollId    String @map("poll_id") @db.Uuid
  poll      Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label     String @db.VarChar(200)
  voteCount Int    @default(0) @map("vote_count")
  sortOrder Int    @default(0) @map("sort_order")

  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  pollId    String     @map("poll_id") @db.Uuid
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String     @map("option_id") @db.Uuid
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String     @map("user_id") @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz

  // One row per (poll, user, option): single-choice polls keep one row,
  // multi-choice polls allow several. Service enforces the single-choice rule.
  @@id([pollId, userId, optionId])
  @@index([optionId])
  @@index([userId])
  @@map("poll_votes")
}

// ── Reviews / Avis ───────────────────────────────────────────────
// A review targets EITHER a user profile OR a page (exactly one of the two
// target FKs is set). Aggregates are denormalised onto User/Page.
model Review {
  id           String           @id @default(uuid()) @db.Uuid
  authorId     String           @map("author_id") @db.Uuid
  author       User             @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetType   ReviewTargetType @map("target_type")
  targetUserId String?          @map("target_user_id") @db.Uuid
  targetUser   User?            @relation("ReviewTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetPageId String?          @map("target_page_id") @db.Uuid
  targetPage   Page?            @relation("ReviewTargetPage", fields: [targetPageId], references: [id], onDelete: Cascade)
  rating       Int
  comment      String?          @db.Text
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // One review per author per target. NULLs are distinct in Postgres, so the
  // two partial uniques don't collide across target types.
  @@unique([authorId, targetUserId])
  @@unique([authorId, targetPageId])
  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([targetPageId, createdAt(sort: Desc)])
  @@map("reviews")
}

// ── Newsletter ───────────────────────────────────────────────────
// Pre-launch waitlist + ongoing newsletter. Single opt-in: an email is stored
// directly when collected via the landing "M'avertir du lancement" form (no
// confirmation email). Every campaign carries a per-subscriber unsubscribe
// token surfaced through the List-Unsubscribe header (RGPD / CAN-SPAM).
enum NewsletterStatus {
  subscribed
  unsubscribed
}

enum CampaignStatus {
  draft
  sending
  sent
  failed
}

model NewsletterSubscriber {
  id               String           @id @default(uuid()) @db.Uuid
  email            String           @unique @db.VarChar(255)
  status           NewsletterStatus @default(subscribed)
  // Where the address came from: 'landing', 'admin', … (free-form, for stats).
  source           String?          @db.VarChar(50)
  locale           String?          @db.VarChar(10)
  // Opaque random token (hex) used for one-click unsubscribe links.
  unsubscribeToken String           @unique @map("unsubscribe_token") @db.VarChar(64)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  unsubscribedAt   DateTime?        @map("unsubscribed_at") @db.Timestamptz

  @@index([status])
  @@map("newsletter_subscribers")
}

model NewsletterCampaign {
  id              String         @id @default(uuid()) @db.Uuid
  subject         String         @db.VarChar(200)
  // Inner HTML body (wrapped in the branded layout at send time) + plain-text part.
  bodyHtml        String         @map("body_html") @db.Text
  bodyText        String         @map("body_text") @db.Text
  status          CampaignStatus @default(draft)
  totalRecipients Int            @default(0) @map("total_recipients")
  sentCount       Int            @default(0) @map("sent_count")
  failedCount     Int            @default(0) @map("failed_count")
  createdById     String?        @map("created_by_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  sentAt          DateTime?      @map("sent_at") @db.Timestamptz

  @@index([status])
  @@map("newsletter_campaigns")
}

// ── Parrainage — Invitation ───────────────────────────────────────
model Invitation {
  id           String           @id @default(uuid()) @db.Uuid
  // Code haute entropie partagé par le parrain. base62, 10+ chars (~59 bits).
  code         String           @unique @db.VarChar(16)
  // null = invitation racine générée par l'admin (bootstrap / seeding waitlist).
  inviterId    String?          @map("inviter_id") @db.Uuid
  inviter      User?            @relation("UserInvitesSent", fields: [inviterId], references: [id], onDelete: Cascade)
  // single_use (défaut) = email/code une acceptation ; reusable = lien de masse.
  kind         InvitationKind   @default(single_use)
  status       InvitationStatus @default(pending)
  // Comptes inscrits via cette invitation (surtout utile pour les liens reusable).
  signups      User[]           @relation("InvitationSignups")
  // Compte créé en consommant ce code. SetNull si ce compte est supprimé,
  // pour garder l'historique de l'invitation.
  acceptedById String?          @map("accepted_by_id") @db.Uuid
  acceptedBy   User?            @relation("UserInviteAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)
  // Data-minimization: email du destinataire ciblé par une invitation email.
  // Normalisé (lowercase+trim) avant stockage. PURGÉ (→ null) dès que
  // l'invitation quitte 'pending' (accept, revoke, expiry). On ne conserve
  // jamais l'email d'un tiers au-delà de la durée de vie de l'invitation.
  targetEmail  String?          @map("target_email") @db.VarChar(254)
  expiresAt    DateTime?        @map("expires_at") @db.Timestamptz
  acceptedAt   DateTime?        @map("accepted_at") @db.Timestamptz
  revokedAt    DateTime?        @map("revoked_at") @db.Timestamptz
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@index([inviterId, status])
  @@index([inviterId, kind])
  @@index([status, expiresAt])
  @@index([status, targetEmail])
  @@map("invitations")
}

// ── Réglages runtime ─────────────────────────────────────────────
// Réutilisable pour tout futur feature-flag.
model AppSetting {
  key         String   @id @db.VarChar(60)        // 'registration_mode', 'default_invite_quota', 'invite_expiry_days'
  value       String   @db.VarChar(100)
  updatedById String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("app_settings")
}
