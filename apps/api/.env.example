# ──────────────────────────────────────────────────────────────────────────────
# NigerConnect API — environment variables reference
# Copy this file to .env and fill in the values for your environment.
# Lines starting with # are comments and are ignored.
# ──────────────────────────────────────────────────────────────────────────────

# ── Core ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
# Used in emails / redirects pointing at the web frontend
APP_WEB_URL=http://localhost:3001

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nigerconnect:nigerconnect@localhost:5433/nigerconnect?schema=public

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (RS256 keypair) ────────────────────────────────────────────────────────
# Generate with: node apps/api/scripts/generate-keys.js
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
# Uncomment during key rotation — the previous public key is accepted for the
# duration of its tokens' remaining TTL.
# JWT_PREVIOUS_PUBLIC_KEY_PATH=./keys/jwt-public-prev.pem
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=14d
JWT_ISSUER=nigerconnect-api
JWT_AUDIENCE=nigerconnect-app

# ── Column encryption (AES-256-GCM) ───────────────────────────────────────────
# Required in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# DATA_ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://10.0.2.2:8081,http://localhost:19000,http://10.0.2.2:19000,http://localhost:3000,http://localhost:3001

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
# For local dev, MinIO is used. For production, replace with real AWS values.
S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_ENDPOINT=http://localhost:9000   # only needed if MinIO is behind a reverse proxy
S3_REGION=us-east-1
S3_BUCKET=nigerconnect
S3_PRIVATE_BUCKET=nigerconnect-private
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# Set to true on real AWS S3 to enable server-side encryption. Leave false for MinIO.
S3_SSE=false
CDN_URL=http://localhost:9000/nigerconnect

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Where to obtain these credentials:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create (or open) an OAuth 2.0 Client ID for each platform.
#   3. For the iOS native build: type = "iOS", bundle ID = com.nigerconnect.app
#   4. For the Android native build: type = "Android", SHA-1 fingerprint required
#   5. For the web / Expo Go flow: type = "Web application", authorised redirect URI
#      = https://auth.expo.io/@<expo-username>/nigerconnect
#
# At least ONE of these four must be set; the API accepts ID tokens issued by
# any of the configured client IDs.
#
# Legacy / web client (also used by Expo Go via auth.expo.io proxy)
GOOGLE_CLIENT_ID=
# Expo web build client ID (type = "Web application")
GOOGLE_CLIENT_ID_WEB=
# Android native client ID (type = "Android")
GOOGLE_CLIENT_ID_ANDROID=
# iOS native client ID (type = "iOS")
GOOGLE_CLIENT_ID_IOS=

# ── Apple Sign In ──────────────────────────────────────────────────────────────
# Where to obtain these credentials:
#   1. Go to https://developer.apple.com/account/resources/identifiers/list
#   2. APPLE_CLIENT_ID → your iOS App ID / bundle identifier, e.g. com.nigerconnect.app
#      This is the "audience" (aud) value in the identity token for native iOS sign-in.
#      Register the capability "Sign In with Apple" on this App ID.
#   3. APPLE_CLIENT_ID_WEB (optional) → a "Services ID" (type = Services)
#      used for web-based Apple sign-in flows. Its identifier looks like
#      com.nigerconnect.app.web (different from the bundle ID).
#      Only required if you implement a web Sign In with Apple button.
#
# IMPORTANT: Without APPLE_CLIENT_ID set, every Apple identity token will be
# rejected with 401 Unauthorized. Set it to your iOS bundle ID at minimum.
APPLE_CLIENT_ID=com.nigerconnect.app
# APPLE_CLIENT_ID_WEB=com.nigerconnect.app.web

# The following Apple credentials are used by server-side Apple auth flows
# (e.g. token revocation, REST API calls). Not needed for pure mobile JWT
# verification, but fill in if you use passport-apple or token revocation.
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_KEY_ID=XXXXXXXXXX
# APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# ── Email ──────────────────────────────────────────────────────────────────────
MAIL_FROM=NigerConnect <no-reply@nigerconnect.local>
# SMTP (Mailhog for local dev: host=localhost port=1025 no auth)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# Resend.com API (alternative to SMTP in production)
# RESEND_API_KEY=

# ── Push notifications (Firebase Cloud Messaging) ──────────────────────────────
# Paste the full contents of your Firebase service account JSON as a single line
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Sentry / Axiom (observability) ────────────────────────────────────────────
# SENTRY_DSN=
# AXIOM_TOKEN=
