# ─────────────────────────────────────────────────────
# NigerConnect Web (Next.js) — variables d'environnement
# Copie en .env.local pour le dev. En prod, configure via
# Vercel → Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────

# URL publique de l'API NestJS (jamais préfixé "/api" — le client le rajoute).
# Dev local :   http://localhost:3000
# Prod :        https://api.nigerconnect.app
NEXT_PUBLIC_API_URL=http://localhost:3000

# DSN Sentry (optionnel — si vide, le reporting est désactivé).
NEXT_PUBLIC_SENTRY_DSN=

# Origine de l'app (pour les meta OG, sitemap, robots, etc.).
# Prod : https://nigerconnect.app
NEXT_PUBLIC_APP_URL=http://localhost:3001
