{
  "expo": {
    "name": "NigerConnect",
    "slug": "nigerconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nigerconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFBF7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nigerconnect.app",
      "buildNumber": "1",
      "usesAppleSignIn": false,
      "associatedDomains": [
        "applinks:nigerconnect.sahabiguide.com",
        "webcredentials:nigerconnect.sahabiguide.com"
      ],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "NigerConnect utilise ton appareil photo pour prendre tes photos de profil, tes publications et tes stories.",
        "NSPhotoLibraryUsageDescription": "NigerConnect accède à tes photos pour choisir ton avatar, tes publications et tes stories.",
        "NSPhotoLibraryAddUsageDescription": "NigerConnect peut enregistrer des photos partagées dans ton téléphone, uniquement lorsque tu le demandes.",
        "NSLocationWhenInUseUsageDescription": "NigerConnect utilise ta position uniquement quand tu l'actives, pour t'afficher sur la carte de la diaspora et trouver des membres proches."
      }
    },
    "android": {
      "package": "com.nigerconnect.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E05206"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_CONTACTS",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "nigerconnect.sahabiguide.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "NigerConnect accède à tes photos uniquement quand tu choisis d'en partager une (avatar, publication, story).",
          "cameraPermission": "NigerConnect utilise ta caméra uniquement quand tu lances la prise d'une photo (avatar, publication, story).",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E05206",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NigerConnect utilise ta position uniquement quand tu l'actives, pour t'afficher sur la carte de la diaspora."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "googleClientIdWeb": "682162626945-mghtoue8lhutmbhbnncommncjgk0ci73.apps.googleusercontent.com",
      "googleClientIdAndroid": "",
      "googleClientIdIos": "",
      "appleSignInEnabled": false,
      "sentryDsn": "",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a3dec8bd-23a8-4f19-89d7-4bf44cd15e5e"
      }
    },
    "owner": "sidi300",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a3dec8bd-23a8-4f19-89d7-4bf44cd15e5e"
    }
  }
}
