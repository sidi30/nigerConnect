# =============================================================================
# NigerConnect — production env template (VPS rag-prod-1)
# =============================================================================
# Copy to `.env.prod` then fill in. The deploy script picks it up via
# `--env-file .env.prod`.
# Variables marked "REQUIRED" must be set or `docker compose up` fails fast.
#
# Single-level subdomain constraint: Cloudflare Universal SSL only covers
# one level of subdomain. We use hyphenated hostnames per service, exactly
# like the existing apps on this host (auth.sahabiguide.com, cs-api.*, etc.):
#     nigerconnect.sahabiguide.com         ← web   (1 level, OK)
#     api-nigerconnect.sahabiguide.com     ← api   (1 level, OK)
#     cdn-nigerconnect.sahabiguide.com     ← cdn   (1 level, OK)
#     api.nigerconnect.sahabiguide.com     ← KO    (2 levels, no free cert)
# =============================================================================

# -----------------------------------------------------------------------------
# Public hostnames (must exist as Cloudflare records, proxied=ON)
# Three subdomains — one per concern, matching the convention of the other
# apps on this host (auth/cs-api/cs-monitoring/etc.).
# -----------------------------------------------------------------------------
WEB_HOST=nigerconnect.sahabiguide.com
API_HOST=api-nigerconnect.sahabiguide.com
CDN_HOST=cdn-nigerconnect.sahabiguide.com

# Public CDN URL — what the browser uses to fetch avatars / post media.
# The path segment matches the public bucket name (Traefik forwards the
# request to MinIO which routes by bucket prefix).
CDN_URL=https://cdn-nigerconnect.sahabiguide.com/nigerconnect

# Comma-separated list of allowed Origin headers for the API (CORS).
# Defaults to https://${WEB_HOST} only. Add temporary entries for local testing
# (e.g. http://localhost:8081 for Expo web), then remove once done.
# CORS_ORIGINS=https://nigerconnect.sahabiguide.com,http://localhost:8081

# -----------------------------------------------------------------------------
# Postgres   (REQUIRED)
# -----------------------------------------------------------------------------
POSTGRES_DB=nigerconnect
POSTGRES_USER=nigerconnect
# Generate a 32-char random password:
#   openssl rand -base64 24
POSTGRES_PASSWORD=__CHANGE_ME__

# -----------------------------------------------------------------------------
# Redis      (REQUIRED)
# -----------------------------------------------------------------------------
# openssl rand -base64 24
REDIS_PASSWORD=__CHANGE_ME__

# -----------------------------------------------------------------------------
# MinIO / S3 (REQUIRED)
# -----------------------------------------------------------------------------
S3_BUCKET=nigerconnect
S3_PRIVATE_BUCKET=nigerconnect-private
S3_REGION=eu-west-1
MINIO_ROOT_USER=nigerconnect
# openssl rand -base64 24
MINIO_ROOT_PASSWORD=__CHANGE_ME__

# -----------------------------------------------------------------------------
# JWT keypair — generated automatically by deploy-vps.sh on first run if
# `secrets/jwt-private.pem` / `secrets/jwt-public.pem` are missing.
# Nothing to set here unless you bring your own pair.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Column-level encryption (REQUIRED) — AES-256, base64 of 32 bytes.
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# -----------------------------------------------------------------------------
DATA_ENCRYPTION_KEY=__CHANGE_ME__

# -----------------------------------------------------------------------------
# OAuth (optional — leave empty to disable a provider)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_IOS=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Mail (Resend recommended in prod) — optional
# -----------------------------------------------------------------------------
RESEND_API_KEY=
MAIL_FROM=NigerConnect <no-reply@sahabiguide.com>

# -----------------------------------------------------------------------------
# Push notifications (FCM) — optional. Base64 of the service-account JSON.
# -----------------------------------------------------------------------------
FCM_SERVICE_ACCOUNT_JSON=

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
