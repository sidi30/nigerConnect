# =============================================================================
# NigerConnect — production env template (VPS rag-prod-1)
# =============================================================================
# Copy to `.env.prod` then fill in. The deploy script picks it up via
# `--env-file .env.prod`.
# Variables marked "REQUIRED" must be set or `docker compose up` fails fast.
#
# Hosts are single-level subdomains of the owned apex nigerconnect.app —
# Cloudflare Universal SSL covers one level, so each gets a free cert:
#     nigerconnect.app          ← web vitrine
#     api.nigerconnect.app      ← API + Socket.io
#     cdn.nigerconnect.app      ← MinIO public bucket
#     tenant.nigerconnect.app   ← admin console (same web container)
# =============================================================================

# -----------------------------------------------------------------------------
# Public hostnames (must exist as Cloudflare A records → 46.224.193.109,
# proxied=ON). One per concern; the admin host is served by the same web
# container (middleware rewrites it onto /admin and 404s /admin on the apex).
# -----------------------------------------------------------------------------
WEB_HOST=nigerconnect.app
API_HOST=api.nigerconnect.app
CDN_HOST=cdn.nigerconnect.app
ADMIN_HOST=tenant.nigerconnect.app

# Public CDN URL — what the browser uses to fetch avatars / post media.
# The path segment matches the public bucket name (Traefik forwards the
# request to MinIO which routes by bucket prefix).
CDN_URL=https://cdn.nigerconnect.app/nigerconnect

# Web app URL — used by the API for password-reset / verify-email links sent
# by mail. MUST point to the web frontend, NOT the API (the API's
# /api/auth/reset-password is POST-only). Required in production.
APP_WEB_URL=https://nigerconnect.app

# Comma-separated list of allowed Origin headers for the API (CORS).
# Defaults to https://${WEB_HOST} only. Add temporary entries for local testing
# (e.g. http://localhost:8081 for Expo web), then remove once done.
# CORS_ORIGINS=https://nigerconnect.app,http://localhost:8081

# -----------------------------------------------------------------------------
# Postgres   (REQUIRED)
# -----------------------------------------------------------------------------
POSTGRES_DB=nigerconnect
POSTGRES_USER=nigerconnect
# Generate a 32-char random password:
#   openssl rand -base64 24
POSTGRES_PASSWORD=__CHANGE_ME__

# -----------------------------------------------------------------------------
# Redis      (REQUIRED)
# -----------------------------------------------------------------------------
# openssl rand -base64 24
REDIS_PASSWORD=__CHANGE_ME__

# -----------------------------------------------------------------------------
# MinIO / S3 (REQUIRED)
# -----------------------------------------------------------------------------
S3_BUCKET=nigerconnect
S3_PRIVATE_BUCKET=nigerconnect-private
S3_REGION=eu-west-1
MINIO_ROOT_USER=nigerconnect
# openssl rand -base64 24
MINIO_ROOT_PASSWORD=__CHANGE_ME__

# -----------------------------------------------------------------------------
# JWT keypair — generated automatically by deploy-vps.sh on first run if
# `secrets/jwt-private.pem` / `secrets/jwt-public.pem` are missing.
# Nothing to set here unless you bring your own pair.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Column-level encryption (REQUIRED) — AES-256, base64 of 32 bytes.
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# -----------------------------------------------------------------------------
DATA_ENCRYPTION_KEY=__CHANGE_ME__

# -----------------------------------------------------------------------------
# OAuth (optional — leave empty to disable a provider)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_IOS=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Mail (Resend recommended in prod) — optional
# -----------------------------------------------------------------------------
RESEND_API_KEY=
MAIL_FROM=NigerConnect <contact@nigerconnect.app>

# -----------------------------------------------------------------------------
# Push notifications (FCM) — optional. Base64 of the service-account JSON.
# -----------------------------------------------------------------------------
FCM_SERVICE_ACCOUNT_JSON=

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# ── PITR / pgBackRest off-site backups (docs/DISASTER_RECOVERY.md) ───────────
# The backup repo MUST be an EXTERNAL S3-compatible bucket (Backblaze B2 /
# Cloudflare R2 / AWS S3) — never the local MinIO (it dies with the VPS).
PGBACKREST_S3_ENDPOINT=s3.eu-central-003.backblazeb2.com
PGBACKREST_S3_BUCKET=nigerconnect-pgbackup
PGBACKREST_S3_REGION=eu-central-003
PGBACKREST_S3_KEY=
PGBACKREST_S3_KEY_SECRET=
PGBACKREST_S3_URI_STYLE=path
# Long random passphrase encrypting the repo at rest. KEEP A COPY OFF-MACHINE —
# losing it makes every backup unrecoverable. Generate: openssl rand -base64 48
PGBACKREST_CIPHER_PASS=
